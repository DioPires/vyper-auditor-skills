{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyper-auditor-skills/schemas/gate-status.schema.json",
  "title": "GateStatus",
  "type": "object",
  "required": ["prod_gate", "assurance_checks", "blocked_reasons", "warnings", "artifact_paths"],
  "additionalProperties": false,
  "properties": {
    "prod_gate": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
    "assurance_checks": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
    "blocked_reasons": {"type": "array", "items": {"type": "string"}},
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "level", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "level": {"type": "string", "enum": ["INFO", "WARN"]},
          "message": {"type": "string", "minLength": 1},
          "source": {"type": "string"},
          "context": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    },
    "critical_high_validation_summary": {
      "type": "object",
      "required": ["total", "confirmed", "rejected", "unverified"],
      "additionalProperties": false,
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "confirmed": {"type": "integer", "minimum": 0},
        "rejected": {"type": "integer", "minimum": 0},
        "unverified": {"type": "integer", "minimum": 0}
      }
    },
    "artifact_paths": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string"}
    }
  }
}
