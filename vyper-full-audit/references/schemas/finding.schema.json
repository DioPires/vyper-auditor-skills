{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyper-auditor-skills/schemas/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "required": [
    "finding_id",
    "rule_id",
    "severity",
    "status",
    "contract",
    "function",
    "span",
    "confidence",
    "evidence",
    "recommendation",
    "source"
  ],
  "additionalProperties": false,
  "properties": {
    "finding_id": {
      "type": "string",
      "pattern": "^FND-[A-Fa-f0-9]{8,64}$"
    },
    "rule_id": {
      "type": "string",
      "minLength": 3
    },
    "severity": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low", "Informational"]
    },
    "status": {
      "type": "string",
      "enum": ["NEW", "RECURRING", "REGRESSION", "ACKNOWLEDGED", "RESOLVED", "INCOMPLETE"]
    },
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "function": {
      "type": "string",
      "minLength": 1
    },
    "span": {
      "type": "object",
      "required": ["start_line", "end_line"],
      "additionalProperties": false,
      "properties": {
        "start_line": {"type": "integer", "minimum": 1},
        "end_line": {"type": "integer", "minimum": 1}
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "content"],
        "additionalProperties": false,
        "properties": {
          "type": {"type": "string", "enum": ["code", "spec", "test", "analysis"]},
          "content": {"type": "string", "minLength": 1}
        }
      }
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["vuln-scan", "spec-compliance", "both"]
    },
    "validation": {
      "type": "object",
      "required": ["assessment", "notes"],
      "additionalProperties": false,
      "properties": {
        "assessment": {"type": "string", "enum": ["CONFIRMED", "REJECTED", "UNVERIFIED"]},
        "notes": {"type": "string"}
      }
    }
  }
}
