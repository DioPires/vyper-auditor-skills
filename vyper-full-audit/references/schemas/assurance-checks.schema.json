{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyper-defi-audit/schemas/assurance-checks.schema.json",
  "title": "AssuranceChecks",
  "type": "object",
  "required": ["status", "dimensions"],
  "additionalProperties": false,
  "properties": {
    "status": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "notes"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
