{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyper-auditor-skills/schemas/assurance-checks.schema.json",
  "title": "AssuranceChecks",
  "type": "object",
  "required": ["meta", "status", "evidence_engines", "dimensions"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at", "schema_pack_version"],
      "additionalProperties": false,
      "properties": {
        "generated_at": {"type": "string"},
        "schema_pack_version": {"type": "string", "minLength": 1}
      }
    },
    "status": {"type": "string", "enum": ["PASS", "BLOCKED"]},
    "evidence_engines": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["boa-pytest", "foundry", "echidna-harness", "other"]
      }
    },
    "execution_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "notes"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string", "enum": ["PASS", "BLOCKED"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
