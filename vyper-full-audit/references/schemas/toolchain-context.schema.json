{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vyper-auditor-skills/schemas/toolchain-context.schema.json",
  "title": "ToolchainContext",
  "type": "object",
  "required": ["meta", "tool_availability", "execution_plan", "warnings"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "generated_at",
        "schema_pack_version",
        "profile",
        "toolchain_mode",
        "tool_timeout_sec",
        "tool_fail_open",
        "requested_tools"
      ],
      "additionalProperties": false,
      "properties": {
        "generated_at": {"type": "string"},
        "schema_pack_version": {"type": "string", "minLength": 1},
        "profile": {"type": "string"},
        "toolchain_mode": {"type": "string", "enum": ["required", "enabled", "disabled"]},
        "tool_timeout_sec": {"type": "integer", "minimum": 1},
        "tool_fail_open": {"type": "boolean"},
        "requested_tools": {
          "type": "array",
          "items": {"type": "string", "enum": ["slither", "mythril", "echidna"]}
        }
      }
    },
    "tool_availability": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "status"],
        "additionalProperties": false,
        "properties": {
          "tool": {"type": "string", "enum": ["slither", "mythril", "echidna"]},
          "status": {"type": "string", "enum": ["AVAILABLE", "MISSING", "ERROR", "TIMEOUT", "SKIPPED"]},
          "version": {"type": "string"},
          "details": {"type": "string"},
          "reason_code": {"type": "string", "pattern": "^TOOLCHAIN:[A-Z0-9_]+$"},
          "install_hint": {"type": "string", "minLength": 1},
          "install_doc_ref": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {"enum": ["MISSING", "ERROR", "TIMEOUT"]}
              }
            },
            "then": {
              "required": ["reason_code", "install_hint", "install_doc_ref"]
            }
          }
        ]
      }
    },
    "execution_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "will_run", "reason"],
        "additionalProperties": false,
        "properties": {
          "tool": {"type": "string", "enum": ["slither", "mythril", "echidna"]},
          "will_run": {"type": "boolean"},
          "reason": {"type": "string"}
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "level", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "level": {"type": "string", "enum": ["INFO", "WARN"]},
          "message": {"type": "string", "minLength": 1},
          "source": {"type": "string"},
          "context": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    }
  }
}
